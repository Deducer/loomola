# Copy this file to .env.local and fill in real values.
# Never commit .env.local.

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Database (direct postgres connection for Drizzle migrations)
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# App
# For a full Deepgram transcript pipeline this must be a public HTTPS origin.
# localhost works for UI/dev, but Deepgram cannot call localhost webhooks.
NEXT_PUBLIC_APP_URL=http://localhost:3000
VIEW_UNLOCK_SECRET=replace-with-openssl-rand-hex-32
VISITOR_HASH_SALT=replace-with-openssl-rand-hex-32

# Object storage — Cloudflare R2 by default, or any S3-compatible store.
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=loomola
# For MinIO/AWS S3: set S3_ENDPOINT and leave R2_ACCOUNT_ID empty.
#   S3_ENDPOINT=http://localhost:9000        # what the SERVER connects to
#   S3_PUBLIC_ENDPOINT=http://localhost:9000 # what the BROWSER connects to (presigned URLs); defaults to S3_ENDPOINT
#   S3_FORCE_PATH_STYLE=true                 # default true when S3_ENDPOINT is set
S3_ENDPOINT=
S3_PUBLIC_ENDPOINT=

# Deepgram transcription
DEEPGRAM_API_KEY=dg_...
DEEPGRAM_CALLBACK_SIGNING_SECRET=replace-with-openssl-rand-hex-32

# AI title/summary/chapters/action items
ANTHROPIC_API_KEY=sk-ant-...
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
# Optional fallback if Anthropic is unavailable.
OPENROUTER_API_KEY=
LLM_FALLBACK_MODEL=google/gemini-2.5-flash

# Embeddings/search. Required when ENABLE_GRANOLA=true and useful for
# semantic search/export features.
OPENAI_API_KEY=sk-...
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# Mailgun notification email. Used for first-view/comment/contact emails.
MAILGUN_API_KEY=key-...
MAILGUN_DOMAIN=mg.example.com
MAIL_FROM_ADDRESS=Loomola <notifications@mg.example.com>
# Contact form: address that receives /api/contact submissions via Mailgun.
CONTACT_INBOX=you@example.com

# macOS desktop app. The installer also accepts these from desktop/.env.local.
LOOM_API_BASE_URL=http://localhost:3000
LOOM_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
LOOM_SUPABASE_ANON_KEY=eyJhbGciOi...

# MCP server: provision MCP_TOKEN in Doppler; keep public access off by default.
MCP_TOKEN=
MCP_ALLOW_PUBLIC=false
# Optional: pin MCP reads to a specific auth.users row; otherwise v1 uses
# the first user because Loomola is single-user today.
MCP_OWNER_ID=
MCP_OWNER_EMAIL=

# Only for running Playwright E2E locally (not deployed)
TEST_CREATOR_EMAIL=your-email@example.com
TEST_CREATOR_PASSWORD=your-password

# Granola-alt / audio meeting notes
ENABLE_GRANOLA=false
INTEGRATION_API_TOKEN=replace-with-openssl-rand-hex-32
TRANSCRIBE_PROVIDER=deepgram
OBSIDIAN_DEFAULT_VAULT_PATH=
